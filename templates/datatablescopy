    <script>
        $(document).ready(function () {
            var table = $('#transactions-table').DataTable({
                "lengthMenu": [
                    [10, 25, 50, 100, -1],
                    [10, 25, 50, 100, 'All']
                ],
                "aaSorting": [],
                "initComplete": function () {
                    this.api().columns().every(function () {
                        let column = this;
                        let index = column.index();
                        let title = $(column.footer()).text();

                        // Only add search input to specific columns (excluding Action column)
                        if (index !== 12) { // Index 12 is the Action column
                            let input = $('<input>').attr('placeholder', 'Search ' + title).addClass('form-control form-control-sm search-input');
                            input.prepend('<i class="fas fa-search"></i>');
                            $(column.footer()).empty().append(input);

                            input.on('keyup change', function () {
                                column.search($(this).val()).draw();
                            });
                        } else {
                            // Remove any existing search input for Action column
                            $(column.footer()).empty();
                        }
                    });
                },
                "footerCallback": function (row, data, start, end, display) {
                    var api = this.api();

                    // Function to format numbers with thousands separators
                    function formatNumber(num) {
                        return num.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    }

                    // Calculate total for Amount column
                    var intVal = function (i) {
                        return typeof i === 'string' ?
                            i.replace(/[\$,]/g, '') * 1 :
                            typeof i === 'number' ?
                                i : 0;
                    };

                    var total_amount = api
                        .column(5, { page: 'current' })
                        .data()
                        .reduce(function (a, b) {
                            return intVal(a) + intVal(b);
                        }, 0);

                    // Update footer with formatted total
                    $(api.column(5).footer()).html(
                        'Total: ' + formatNumber(total_amount)
                    );
                }
            });

            // Trigger initial update of footer totals
            table.draw();
        });


        // Function to delete a transaction
        window.deleteTransaction = function (event, transactionId) {
            event.preventDefault(); // Prevent default link behavior

            if (confirm('Are you sure you want to delete this transaction?')) {
                $.ajax({
                    url: '/delete_transaction/' + transactionId,
                    type: 'POST',
                    success: function (response) {
                        if (response.success) {

                            const row = $(`a[data-id="${transactionId}"]`).closest('tr');
                            alert('Transaction has been deleted successfully.');
                            table.row(row).remove().draw();
                            // Optionally refresh the DataTable (if you want to ensure it's updated with server data)
                            table.ajax.reload(null, false); // false keeps the current page

                        } else {
                            alert('Failed to delete transaction: ' + response.error);
                        }
                    },
                    error: function (xhr, status, error) {
                        alert('Failed to delete transaction. Transaction does not exist.');
                    }
                });
            }
        };

    </script>


