                                </tr>
                            </thead>
                            <tbody>
                                {% for transaction in transactions %}
                                <tr>
                                    <td>{{ transaction.date.strftime('%Y-%m-%d') }}</td>
                                    <td>{{ transaction.transaction_type }}</td>
                                    <td>{{ transaction.category.category if transaction.category else 'N/A' }}</td>
                                    <td>{{ transaction.chart_of_accounts.sub_category }}</td>
                                    <td>{{ transaction.currency }}</td>
                                    <td>{{ "{:,.0f}".format(transaction.amount) }}</td>
                                    <td>{{ transaction.dr_cr }}</td>
                                    <td>{{ transaction.description }}</td>
                                    <td>{{ transaction.payment_mode.payment_mode if transaction.payment_mode else 'N/A'
                                        }}</td>
                                    <td>{{ transaction.vendor.vendor_name if transaction.vendor else 'N/A' }}</td>
                                    <td>{{ transaction.project.name if transaction.project else 'N/A' }}</td>
                                    <td>{{ transaction.date_added }}</td>
